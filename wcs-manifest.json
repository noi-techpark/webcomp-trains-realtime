  "image": "wcs-logo.png",
  "searchTags": ["trains", "realtime", "south-tyrol", "siri", "public-transport", "map", "leaflet"],
  "dist": {
    "basePath": "dist",
    "files": ["webcomp-trains-realtime-sta.min.js"],
    "scripts": []
  },
  "configuration": {
    "tagName": "trains-realtime-sta",
    "options": [
      {
        "key": "dataset-id",
        "type": "text",
        "label": "SIRI dataset ID",
        "required": false,
        "options": { "default": "SADtrains" }
      },
      {
        "key": "siri-url",
        "type": "text",
        "label": "Custom SIRI endpoint URL (overrides dataset-id when set)",
        "required": false,
        "options": { "default": "" }
      },
      {
        "key": "refresh-interval",
        "type": "number",
        "label": "Auto-refresh interval in seconds (minimum 10)",
        "required": false,
        "options": { "default": 30 }
      },
      {
        "key": "height",
        "type": "text",
        "label": "Map height (any CSS length value)",
        "required": false,
        "options": { "default": "500px" }
      }
    ]
  }
}
