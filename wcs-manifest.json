{
  "title": "Trains Realtime – South Tyrol",
  "shortName": "trains-realtime-sta",
  "description": "Displays real-time train positions on a map using the SIRI-lite vehicle monitoring feed.",
  "descriptionAbstract": "Real-time train position map for South Tyrol powered by the SIRI-lite JSON feed. Shows all active trains with line labels, delay colour-coding (green/orange/red) and a click-to-open popup with full journey details.",
